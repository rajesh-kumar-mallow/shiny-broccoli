{
  "name": "shiny-broccoli",
  "private": true,
  "version": "2026.06.25.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:userscript": "vite build",
    "build:stylus": "node scripts/build-stylus.mjs",
    "build": "npm run build:userscript && npm run build:stylus",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run check && npm run lint && npm run format:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.5",
    "vite-plugin-monkey": "^5.0.3"
  }
}
